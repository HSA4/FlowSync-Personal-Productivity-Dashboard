# FlowSync Environment Variables

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=flowsync
POSTGRES_SSL_MODE=prefer

# ============================================
# Redis (Caching & Message Broker)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=

# ============================================
# Celery (Background Tasks)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ============================================
# Application
# ============================================
API_BASE_URL=http://localhost:8000
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Security
# ============================================
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# OAuth (Google)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# ============================================
# External Integrations
# ============================================
# Todoist
TODOIST_CLIENT_ID=your-todoist-client-id
TODOIST_CLIENT_SECRET=your-todoist-client-secret
TODOIST_WEBHOOK_SECRET=your-todoist-webhook-secret-optional

# ============================================
# AI / OpenRouter
# ============================================
# Get your API key at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3-haiku:beta
OPENROUTER_SITE_URL=https://flowsync.app
OPENROUTER_APP_NAME=FlowSync

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
